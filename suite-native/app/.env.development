EXPO_PUBLIC_ENVIRONMENT=debug
EXPO_PUBLIC_BLUETOOTH_ENABLED=true

### Create .env.development.local files and copy there what you want to override for you locally

# EXPO_PUBLIC_IS_ANALYTICS_LOGGER_ENABLED=true
# EXPO_PUBLIC_IS_SENTRY_ON_DEBUG_BUILD_ENABLED=true # always enabled outside debug build


### Initial states for Feature Flags, see suite-native/feature-flags/src/featureFlagsSlice.ts

# EXPO_PUBLIC_FF_IS_DEVICE_CONNECT_ENABLED=true
# EXPO_PUBLIC_FF_IS_BLUETOOTH_ENABLED=true
# EXPO_PUBLIC_FF_IS_CARDANO_SEND_ENABLED=true
# EXPO_PUBLIC_FF_IS_REGTEST_ENABLED=true
# EXPO_PUBLIC_FF_IS_CONNECT_POPUP_ENABLED=true
# EXPO_PUBLIC_FF_IS_TRADING_ENABLED=true
# EXPO_PUBLIC_FF_IS_WALLET_CONNECT_ENABLED=true
