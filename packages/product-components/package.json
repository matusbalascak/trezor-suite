        "@trezor/env-utils": "workspace:*",
        "@trezor/react-utils": "workspace:*",
        "@trezor/theme": "workspace:*",
        "@trezor/urls": "workspace:*",
        "@trezor/utils": "workspace:*",
        "framer-motion": "^12.6.3",
        "react": "18.2.0",
        "react-hook-form": "^7.54.2",
        "react-intl": "^7.1.11",
